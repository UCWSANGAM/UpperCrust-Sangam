generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  RELATIONSHIP_MANAGER
  OPERATIONS
  RESEARCH
  COMPLIANCE
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          Role      @default(RELATIONSHIP_MANAGER)
  isActive      Boolean   @default(true)
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  branchId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  devices       DeviceSession[]
  notes         Note[]
  assignedTasks Task[] @relation("AssignedTasks")
  createdTasks  Task[] @relation("CreatedTasks")
  quarterlyReviews QuarterlyReview[]
  productUpdates   InvestorProduct[]
  messages         Message[]
  taskComments     TaskComment[]
  assignedTickets  Ticket[] @relation("AssignedTickets")
  createdTickets   Ticket[] @relation("CreatedTickets")
  ticketComments   TicketComment[]
}

// Persistent revocation store — supports instant logout / force logout
model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked     Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model DeviceSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo  String
  ipAddress   String
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// Large imports (5,000+ rows) run in the background, not inline in the HTTP request —
// Railway's edge network will kill a connection held open that long. The upload returns
// immediately with a job id; the frontend polls this record for progress.
model ImportJob {
  id           String          @id @default(uuid())
  status       ImportJobStatus @default(PENDING)
  totalRows    Int             @default(0)
  processedRows Int            @default(0)
  created      Int             @default(0)
  updated      Int             @default(0)
  unmatchedRMs Json?
  errorMessage String?
  createdById  String
  createdAt    DateTime        @default(now())
  finishedAt   DateTime?
}

// Firm-wide internal chat — a single shared channel for now, simplest useful version.
model Message {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Follow-up thread on a task/meeting — separate from investor Notes, scoped to the task itself.
model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([taskId])
}

// Core CRM entity — mirrors distributor investor-book structure
model Investor {
  id                String   @id @default(uuid())
  ucc               String?  @unique
  name              String
  email             String?
  location          String?
  panEncrypted      String?  // stored AES-256 encrypted at the application layer, never plaintext
  mobileEncrypted   String?
  dateOfBirth       DateTime?
  anniversaryDate   DateTime?
  gender            String?
  taxStatus         String?
  ownerId           String?  // RM/partner owning this investor
  familyGroup       String?

  totalMfAum        Decimal? @db.Decimal(18, 2)
  equityAum         Decimal? @db.Decimal(18, 2)
  debtAum           Decimal? @db.Decimal(18, 2)
  cashAum           Decimal? @db.Decimal(18, 2)
  goldAum           Decimal? @db.Decimal(18, 2)
  pmsAum            Decimal? @db.Decimal(18, 2)
  totalAumMfPms     Decimal? @db.Decimal(18, 2)

  xirrEquity        Decimal? @db.Decimal(6, 2)
  xirrDebt          Decimal? @db.Decimal(6, 2)
  xirrTotal         Decimal? @db.Decimal(6, 2)

  // Sales tracking — fiscal year (FY) and calendar year (CY)
  netSalesFY        Decimal? @db.Decimal(18, 2)
  grossSalesFY      Decimal? @db.Decimal(18, 2)
  redemptionsFY     Decimal? @db.Decimal(18, 2)
  netSalesCY        Decimal? @db.Decimal(18, 2)
  grossSalesCY      Decimal? @db.Decimal(18, 2)
  redemptionsCY     Decimal? @db.Decimal(18, 2)
  liveSipAmount     Decimal? @db.Decimal(18, 2)
  liveSipCount      Int?

  // SIP-specific and NFO sales — lets Sales break out SIP vs lumpsum, and NFO participation
  sipGrossSalesFY   Decimal? @db.Decimal(18, 2)
  sipNetSalesFY     Decimal? @db.Decimal(18, 2)
  sipGrossSalesCY   Decimal? @db.Decimal(18, 2)
  sipNetSalesCY     Decimal? @db.Decimal(18, 2)
  nfoGrossSalesFY   Decimal? @db.Decimal(18, 2)
  nfoGrossSalesCY   Decimal? @db.Decimal(18, 2)
  nfoSipSalesFY     Decimal? @db.Decimal(18, 2)
  nfoSipSalesCY     Decimal? @db.Decimal(18, 2)

  // Additional sales dimensions — SWP, top-up SIPs, tax-saving sales, PMS/FD sales
  swpCount          Int?
  swpAmount         Decimal? @db.Decimal(18, 2)
  topUpSipAmount    Decimal? @db.Decimal(18, 2)
  taxPlanSalesFY    Decimal? @db.Decimal(18, 2)
  taxPlanSalesCY    Decimal? @db.Decimal(18, 2)
  pmsSalesFY        Decimal? @db.Decimal(18, 2)
  pmsSalesCY        Decimal? @db.Decimal(18, 2)
  fdBondSalesFY     Decimal? @db.Decimal(18, 2)
  fdBondSalesCY     Decimal? @db.Decimal(18, 2)

  // Needs & gap analysis — drives cross-sell opportunity detection
  totalNeedsIdentified   Int?
  mappedNeedWithGap      Int?
  totalLumpsumGapAmount  Decimal? @db.Decimal(18, 2)
  totalSipGapAmount      Decimal? @db.Decimal(18, 2)

  healthScore       Int?
  lastImportedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  folios            Folio[]
  notes             Note[]
  tasks             Task[]
  quarterlyReviews  QuarterlyReview[]
  productHoldings   InvestorProduct[]

  @@index([ownerId])
  @@index([familyGroup])
}

model Note {
  id          String   @id @default(uuid())
  investorId  String
  investor    Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  content     String
  createdAt   DateTime @default(now())

  @@index([investorId])
}

// Fixed catalog of products the firm sells — seeded once, editable by admins.
model Product {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String?
  sortOrder   Int      @default(0)

  holdings    InvestorProduct[]
}

// One row per investor per product — tracks current holding status and, when relevant,
// AUM in that product. This is what powers the cross-sell eligibility matrix.
enum ProductStatus {
  HOLDS
  NOT_HOLDING
  NOT_ELIGIBLE
}

model InvestorProduct {
  id          String        @id @default(uuid())
  investorId  String
  investor    Investor      @relation(fields: [investorId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  status      ProductStatus @default(NOT_HOLDING)
  amount      Decimal?      @db.Decimal(18, 2)
  updatedById String?
  updatedBy   User?         @relation(fields: [updatedById], references: [id])
  updatedAt   DateTime      @updatedAt

  @@unique([investorId, productId])
  @@index([investorId])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TaskType {
  TASK
  MEETING
}

model Task {
  id          String     @id @default(uuid())
  type        TaskType   @default(TASK)
  title       String
  notes       String?
  dueAt       DateTime?
  status      TaskStatus @default(OPEN)
  investorId  String?
  investor    Investor?  @relation(fields: [investorId], references: [id], onDelete: SetNull)
  assigneeId  String
  assignee    User       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User       @relation("CreatedTasks", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  comments    TaskComment[]

  @@index([assigneeId])
  @@index([investorId])
  @@index([status])
}

model Folio {
  id             String   @id @default(uuid())
  investorId     String
  investor       Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  folioNumber    String
  amc            String
  scheme         String
  option         String?
  balanceUnits   Decimal? @db.Decimal(18, 4)
  currentValue   Decimal? @db.Decimal(18, 2)
  status         String?
  asOnDate       DateTime?
  createdAt      DateTime @default(now())

  @@index([investorId])
}

// One review per investor per quarter — RM confirms contact was made, discusses
// cross-sell, and logs any needs/action items. Enforced unique so it can't be duplicated.
model QuarterlyReview {
  id                  String   @id @default(uuid())
  investorId          String
  investor            Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  reviewerId          String
  reviewer            User     @relation(fields: [reviewerId], references: [id])
  year                Int
  quarter             Int      // 1-4
  contactMade         Boolean  @default(false)
  riskProfileReviewed Boolean  @default(false)
  crossSellDiscussed  Boolean  @default(false)
  notes               String?
  actionItems         String?
  createdAt           DateTime @default(now())

  @@unique([investorId, year, quarter])
  @@index([reviewerId])
}

enum TicketWorkType {
  CLIENT_ONBOARDING
  KYC_COMPLIANCE
  PORTFOLIO_REVIEW
  REDEMPTION_WITHDRAWAL
  DOCUMENTATION
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

// A raised work item, tagged to a colleague — distinct from Team Chat (broadcast)
// and Task (personal to-do). Admins see every ticket; everyone else sees only
// tickets they raised or were assigned.
enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id           String         @id @default(uuid())
  workType     TicketWorkType
  priority     TicketPriority @default(MEDIUM)
  title        String
  description  String?
  status       TicketStatus   @default(OPEN)
  dueAt        DateTime?
  assignedToId String
  assignedTo   User           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User           @relation("CreatedTickets", fields: [createdById], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  comments     TicketComment[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
}

// Discussion thread on a ticket — turns it into a real helpdesk conversation,
// not just a status tracker.
model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// One row per calendar day — captured after each import. Starts accumulating now
// so trend charts (AUM growth over time) have real data to draw from in a few weeks.
model DailySnapshot {
  id             String   @id @default(uuid())
  date           DateTime @unique @db.Date
  totalAum       Decimal? @db.Decimal(18, 2)
  equityAum      Decimal? @db.Decimal(18, 2)
  debtAum        Decimal? @db.Decimal(18, 2)
  cashAum        Decimal? @db.Decimal(18, 2)
  goldAum        Decimal? @db.Decimal(18, 2)
  pmsAum         Decimal? @db.Decimal(18, 2)
  investorCount  Int      @default(0)
  createdAt      DateTime @default(now())
}
