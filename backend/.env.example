# --- Supabase Postgres ---
# Supabase dashboard -> Settings -> Database -> Connection string
# DATABASE_URL = "Transaction" pooler (port 6543) -> used by the running app
# DIRECT_URL   = "Session" / direct connection (port 5432) -> used only for migrations
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xxxx.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xxxx.pooler.supabase.com:5432/postgres

REDIS_URL=redis://default:password@host:6379

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Generate with: openssl rand -base64 32 — used for AES-256 field encryption of PAN/mobile
FIELD_ENCRYPTION_KEY=

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-frontend.up.railway.app

PORT=3001
